.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 登录区域 */
.login-section {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.login-btn {
  width: 400rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  margin: 20rpx;
  padding: 30rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 区块 */
.section {
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-action {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #4A90D9;
}

/* 群组列表 */
.group-list {
  padding: 0 20rpx;
}

.group-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.group-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
}

.group-info {
  flex: 1;
}

.group-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.group-members {
  font-size: 24rpx;
  color: #999;
}

/* 打卡列表 */
.checkin-list {
  padding: 0 20rpx;
}

.checkin-item {
  margin-bottom: 20rpx;
}

.checkin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.checkin-date {
  font-size: 26rpx;
  color: #999;
}

.checkin-content {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 图标字体 */
.iconfont {
  font-family: "iconfont";
}

.icon-add::before {
  content: "+";
  margin-left: 8rpx;
}

.icon-arrow-right::before {
  content: ">";
  color: #ccc;
}
