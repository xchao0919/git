.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 群组头部 */
.group-header {
  display: flex;
  padding: 30rpx;
  background: #fff;
}

.group-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
}

.group-info {
  flex: 1;
}

.group-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.group-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.group-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.role-tag {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.role-tag.owner {
  background: rgba(255, 152, 0, 0.1);
  color: #ff9800;
}

.role-tag.admin {
  background: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

/* 操作按钮 */
.action-section {
  display: flex;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin: 0 8rpx;
}

.action-btn.primary {
  background: #4A90D9;
  color: #fff;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-btn text:last-child {
  font-size: 24rpx;
}

/* 区块 */
.section {
  margin: 20rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 26rpx;
  color: #999;
}

/* 打卡列表 */
.checkin-list {
  margin-top: 20rpx;
}

.checkin-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.checkin-item:last-child {
  border-bottom: none;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.checkin-info {
  flex: 1;
  overflow: hidden;
}

.nickname {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.content {
  display: block;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  font-size: 22rpx;
  color: #ccc;
}

/* 规则列表 */
.rule-list {
  margin-top: 16rpx;
}

.rule-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

/* 底部操作按钮 */
.bottom-actions {
  margin: 40rpx 20rpx;
  padding-bottom: 40rpx;
}

.action-button {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-button.quit {
  background: #fff;
  color: #e74c3c;
  border: 2rpx solid #e74c3c;
}

.action-button.dissolve {
  background: #e74c3c;
  color: #fff;
  border: none;
}

/* 空状态 */
.empty {
  padding: 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: #999;
}
