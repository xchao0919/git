<view class="container">
  <!-- 封面 -->
  <view class="cover-section">
    <view class="cover-box" bindtap="handleChooseCover">
      <image
        wx:if="{{coverFile}}"
        src="{{coverFile}}"
        mode="aspectFill"
      ></image>
      <view wx:else class="cover-placeholder">
        <text class="cover-icon">+</text>
        <text class="cover-text">上传封面</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="form-section card">
    <view class="section-title">基本信息</view>

    <view class="form-item">
      <text class="form-label">群组名称</text>
      <input
        class="form-input"
        placeholder="请输入群组名称"
        value="{{form.name}}"
        bindinput="handleNameInput"
        maxlength="20"
      />
    </view>

    <view class="form-item">
      <text class="form-label">群组描述</text>
      <textarea
        class="form-textarea"
        placeholder="请输入群组描述（选填）"
        value="{{form.description}}"
        bindinput="handleDescInput"
        maxlength="200"
      ></textarea>
    </view>
  </view>

  <!-- 打卡设置 -->
  <view class="form-section card">
    <view class="section-title">打卡设置</view>

    <view class="form-item">
      <text class="form-label">文字最少字数</text>
      <input
        class="form-input"
        type="number"
        placeholder="最少字数"
        value="{{form.checkInConfig.minWords}}"
        bindinput="handleMinWordsChange"
      />
    </view>

    <view class="form-item switch-item">
      <text class="form-label">要求上传图片</text>
      <switch
        checked="{{form.checkInConfig.requireImage}}"
        bindchange="toggleRequireImage"
        color="#4A90D9"
      />
    </view>

    <view class="form-item switch-item">
      <text class="form-label">要求上传视频</text>
      <switch
        checked="{{form.checkInConfig.requireVideo}}"
        bindchange="toggleRequireVideo"
        color="#4A90D9"
      />
    </view>

    <view class="form-item switch-item">
      <text class="form-label">要求上传语音</text>
      <switch
        checked="{{form.checkInConfig.requireAudio}}"
        bindchange="toggleRequireAudio"
        color="#4A90D9"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="submit-btn" bindtap="handleSubmit">创建群组</button>
  </view>
</view>
