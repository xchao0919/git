<view class="container">
  <!-- 用户信息 -->
  <view class="user-section" wx:if="{{isLoggedIn}}">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <text class="user-name">{{userInfo.nickName || '微信用户'}}</text>
  </view>

  <!-- 设置列表 -->
  <view class="setting-section">
    <view class="setting-group">
      <view class="setting-item" bindtap="goToAbout">
        <text class="item-icon">ℹ️</text>
        <text class="item-label">关于我们</text>
        <text class="item-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToPrivacy">
        <text class="item-icon">🔒</text>
        <text class="item-label">隐私政策</text>
        <text class="item-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="handleFeedback">
        <text class="item-icon">💬</text>
        <text class="item-label">反馈建议</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <view class="setting-group">
      <view class="setting-item" bindtap="handleClearCache">
        <text class="item-icon">🗑️</text>
        <text class="item-label">清除缓存</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <view class="setting-group" wx:if="{{isLoggedIn}}">
      <view class="setting-item danger" bindtap="handleLogout">
        <text class="item-icon">🚪</text>
        <text class="item-label">退出登录</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <!-- 版本信息 -->
    <view class="version-info">
      <text>版本号 v{{version}}</text>
    </view>
  </view>
</view>
