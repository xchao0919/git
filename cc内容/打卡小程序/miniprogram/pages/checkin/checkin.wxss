.container {
  padding: 20rpx;
  padding-bottom: 200rpx;
}

/* 群组卡片 */
.group-card {
  padding: 24rpx;
}

.group-header {
  display: flex;
  align-items: center;
}

.group-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.group-info {
  flex: 1;
}

.switch-hint {
  font-size: 24rpx;
  color: #4A90D9;
  padding: 8rpx 16rpx;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 20rpx;
}

.group-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.group-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 选择群组卡片 */
.select-group-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 24rpx;
  background: #f0f7ff;
  border: 2rpx dashed #4A90D9;
}

.select-hint {
  font-size: 30rpx;
  color: #4A90D9;
}

.select-arrow {
  font-size: 24rpx;
  color: #4A90D9;
}

/* 状态卡片 */
.status-card {
  text-align: center;
  padding: 40rpx;
}

.status-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.status-icon.checked {
  color: #52c41a;
}

.status-icon.unchecked {
  color: #999;
}

.status-text {
  font-size: 28rpx;
  color: #666;
}

/* 表单卡片 */
.form-card {
  margin-top: 20rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.required {
  color: #f5222d;
  margin-left: 8rpx;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
}

.add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}

/* 视频/音频区域 */
.video-section, .audio-section {
  position: relative;
}

.video-preview {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  color: #666;
}

.add-btn .add-icon {
  margin-right: 16rpx;
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  background: #4A90D9;
  color: #fff;
  border-radius: 40rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
}

/* 提示卡片 */
.tips-card {
  margin-top: 20rpx;
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #d48806;
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: #d48806;
  line-height: 2;
}

/* 加载中 */
.loading-card {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 群组选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.picker-content {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.picker-list {
  max-height: 60vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-item.active {
  background: rgba(74, 144, 217, 0.1);
}

.picker-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.picker-info {
  flex: 1;
}

.picker-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.picker-count {
  font-size: 24rpx;
  color: #999;
}

.picker-check {
  font-size: 36rpx;
  color: #4A90D9;
}

.picker-empty {
  padding: 60rpx;
  text-align: center;
  color: #999;
}

/* 书籍区域 */
.book-section {
  margin-top: 20rpx;
  padding: 24rpx;
}

.book-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.book-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.chapter-nav {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 20rpx;
}

.nav-btn[disabled] {
  opacity: 0.5;
}

.chapter-index {
  font-size: 22rpx;
  color: #999;
}

.chapter-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #4A90D9;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.chapter-content {
  max-height: 400rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

/* 打卡类型选择 */
.checkin-type {
  margin-bottom: 20rpx;
}

.type-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 6rpx;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 26rpx;
}

.type-tab.active {
  background: #4A90D9;
  color: #fff;
}

/* 阅读录音 */
.reading-record {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
}

.record-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.record-duration {
  font-size: 28rpx;
  color: #4A90D9;
}

.play-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 20rpx;
}

.record-actions {
  display: flex;
  gap: 16rpx;
}

.record-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 30rpx;
  font-size: 30rpx;
}

.record-btn.recording {
  background: #e74c3c;
}

.record-icon {
  margin-right: 12rpx;
}

.delete-btn-small {
  padding: 24rpx;
  background: #fff;
  color: #e74c3c;
  border: 1rpx solid #e74c3c;
  border-radius: 30rpx;
  font-size: 28rpx;
}
