.container {
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 统计卡片 */
.stats-section {
  margin-bottom: 20rpx;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(135deg, #4A90D9 0%, #667eea 100%);
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.stats-num.highlight {
  color: #ffd700;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 日历 */
.calendar-section {
  margin-bottom: 20rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.calendar-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #4A90D9;
}

.calendar-body {
  padding-top: 20rpx;
}

.calendar-week {
  display: flex;
}

.calendar-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
  position: relative;
}

.calendar-day.header {
  font-size: 24rpx;
  color: #999;
}

.calendar-day.checked {
  color: #4A90D9;
  font-weight: bold;
}

.calendar-day.today text {
  background: #4A90D9;
  color: #fff;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-dot {
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #52c41a;
  border-radius: 50%;
}

/* 排行榜 */
.ranking-section {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.ranking-list {
  margin-top: 20rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-rank {
  width: 50rpx;
  text-align: center;
}

.rank-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background: #ff9800;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
}

.rank-text {
  font-size: 28rpx;
  color: #999;
}

.ranking-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin: 0 20rpx;
}

.ranking-info {
  flex: 1;
}

.ranking-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.ranking-role {
  font-size: 22rpx;
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 10rpx;
}

.ranking-count {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: bold;
}

/* 空状态 */
.empty {
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: #999;
}
