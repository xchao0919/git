<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-section">
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-num">{{userStats.totalDays}}</text>
        <text class="stats-label">累计打卡</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-num highlight">{{userStats.continuousDays}}</text>
        <text class="stats-label">连续打卡</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-num">{{userStats.monthDays}}</text>
        <text class="stats-label">本月打卡</text>
      </view>
    </view>
  </view>

  <!-- 日历 -->
  <view class="calendar-section card">
    <view class="calendar-header">
      <view class="calendar-nav" bindtap="prevMonth">
        <text>‹</text>
      </view>
      <text class="calendar-title">{{currentMonth}}</text>
      <view class="calendar-nav" bindtap="nextMonth">
        <text>›</text>
      </view>
    </view>

    <view class="calendar-body">
      <view class="calendar-week" wx:for="{{calendar}}" wx:key="index" wx:for-index="weekIndex">
        <view
          class="calendar-day {{item.isHeader ? 'header' : ''}} {{item.checked ? 'checked' : ''}} {{item.isToday ? 'today' : ''}}"
          wx:for="{{item}}"
          wx:key="day"
        >
          <text>{{item.day}}</text>
          <view class="check-dot" wx:if="{{item.checked}}"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 排行榜 -->
  <view class="ranking-section card" wx:if="{{rankingList.length > 0}}">
    <view class="section-title">打卡排行榜</view>
    <view class="ranking-list">
      <view class="ranking-item" wx:for="{{rankingList}}" wx:key="userId">
        <view class="ranking-rank">
          <text class="rank-num" wx:if="{{index < 3}}">{{index + 1}}</text>
          <text class="rank-text" wx:else>{{index + 1}}</text>
        </view>
        <image class="ranking-avatar" src="{{item.userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="ranking-info">
          <text class="ranking-name">{{item.userInfo.nickName || '未知用户'}}</text>
          <text class="ranking-role" wx:if="{{item.role === 1}}">群主</text>
          <text class="ranking-role" wx:elif="{{item.role === 2}}">管理员</text>
        </view>
        <text class="ranking-count">{{item.checkInCount}}次</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!groupId && rankingList.length === 0}}">
    <text class="empty-text">选择群组查看统计数据</text>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
