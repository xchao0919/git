/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333;
  /* iPhone X+ 底部 Home 条安全区 */
  --safe-bottom: env(safe-area-inset-bottom);
}

/* 安全区工具类 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 底部固定栏：自动留出 safe-area */
.fixed-bottom-bar {
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 主题色 */
.theme-primary {
  color: #4A90D9;
}

.bg-primary {
  background-color: #4A90D9;
}

/* 布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.mr-10 { margin-right: 10rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 卡片 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 按钮 */
.btn-primary {
  background-color: #4A90D9;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-primary:active {
  background-color: #3a7bc8;
}

.btn-outline {
  background-color: #fff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 40rpx;
  padding: 18rpx 38rpx;
  text-align: center;
  font-size: 30rpx;
}

/* 输入框 */
.input {
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 20rpx 0;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
